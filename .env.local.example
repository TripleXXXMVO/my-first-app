# Supabase — public (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — server-only (NEVER expose to browser)
# Required for account deletion (GDPR) and admin user management
# Used in: /api/profile DELETE, /api/admin/users/[id] DELETE
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — required for PROJ-4 Subscription & Payment
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_PRO_PRICE_ID=price_your-pro-plan-price-id

# Optional: set this if your app runs on a custom domain (used for Stripe redirect URLs)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Upstash Redis — optional, for persistent rate limiting across restarts & instances
# Without these, rate limiting falls back to in-memory (resets on restart, single-instance only).
# Create a free Redis database at https://console.upstash.com and copy the REST credentials.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
